# ---- OpenAI ----
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Real public model id. gpt-4o-mini is cheap (~pennies per 10-agent run);
# bump to gpt-4o for richer agent narratives. Avoid fictional ids.
OPENAI_MODEL=gpt-4o-mini

# Offline / demo-insurance mode. Auto-enabled when no OPENAI_API_KEY is set.
# When true the full pipeline runs on deterministic math + templated narrative
# with ZERO network calls — the demo works with no internet.
OPENAI_DISABLED=false

# ---- Database ----
# SQLite locally. Swap for a postgresql+psycopg2 URL on AWS Aurora in prod:
#   DATABASE_URL=postgresql+psycopg2://user:pass@<aurora-host>:5432/udyammitra
DATABASE_URL=sqlite:///./data/udyammitra.db

# ---- Server ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# Comma-separated origins allowed by CORS. On AWS, set to the Amplify frontend URL.
CORS_ORIGINS=http://localhost:3000

# ---- Alternate-data connectors (Problem Statement 3) ----
# All optional. When unset, connectors raise NotImplementedError on live calls
# and the app falls back to seeded/synthetic data. Wire real credentials in
# AWS Secrets Manager for prod (see infra/cdk).
GSP_ASP_BASE_URL=
GSP_ASP_TOKEN=
SAHAMATI_AA_BASE_URL=
SAHAMATI_AA_CLIENT_ID=
EPFO_BASE_URL=